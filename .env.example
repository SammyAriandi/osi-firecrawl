# ============================================
# .env - Environment Configuration
# PT Optima Smartindo Industry
# ============================================
# IMPORTANT: Copy this file to project root as ".env"
# and update sensitive values before deployment

# ============================================
# SYSTEM CONFIGURATION
# ============================================
TZ=Asia/Jakarta
LOG_LEVEL=info
ENVIRONMENT=production  # production, staging, development

# ============================================
# DATABASE - PostgreSQL
# ============================================
# Main ERP Database
POSTGRES_USER=optima_user
POSTGRES_PASSWORD=OptimaSmartin123!@#  # CHANGE THIS IN PRODUCTION!
POSTGRES_DB=optima_erp
POSTGRES_PORT=5432

# Firecrawl Database
FIRECRAWL_DB_USER=firecrawl_user
FIRECRAWL_DB_PASSWORD=FirecrawlPass123!@#  # CHANGE THIS IN PRODUCTION!
FIRECRAWL_DB_NAME=firecrawl_db
FIRECRAWL_DB_PORT=5433

# ============================================
# N8N CONFIGURATION
# ============================================
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=http  # Change to https in production
N8N_WEBHOOK_URL=http://localhost:5678/  # Update with your domain
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=Optima2024!@#  # CHANGE THIS IN PRODUCTION!
N8N_LOG_LEVEL=info

# ============================================
# FIRECRAWL CONFIGURATION
# ============================================
FIRECRAWL_API_PORT=3002
FIRECRAWL_API_KEY=firecrawl_local_key_${RANDOM}  # Auto-generated

# === LLM Provider Selection ===
# Choose ONE of the following options:

# Option 1: OpenAI (Recommended for production)
LLM_PROVIDER=openai
LLM_API_KEY=sk-proj-YOUR_OPENAI_API_KEY_HERE
LLM_MODEL_NAME=gpt-4-turbo
OPENAI_ORG_ID=  # Optional

# Option 2: Claude via OpenRouter
# LLM_PROVIDER=openrouter
# LLM_API_KEY=sk-or-YOUR_OPENROUTER_KEY
# LLM_MODEL_NAME=anthropic/claude-3-sonnet
# OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# Option 3: Ollama (Local, FREE - Good for testing)
# LLM_PROVIDER=ollama
# OLLAMA_API_BASE=http://firecrawl-ollama:11434
# LLM_MODEL_NAME=mistral
# LLM_API_KEY=dummy

# ============================================
# FIRECRAWL SCRAPING SETTINGS
# ============================================
FIRECRAWL_USE_DB_AUTH=false  # false untuk intranet lokal
FIRECRAWL_PLAYWRIGHT_TIMEOUT=30000  # 30 seconds
FIRECRAWL_CRAWL_TIMEOUT=300000  # 5 minutes
FIRECRAWL_MAX_CRAWL_DEPTH=3
FIRECRAWL_MAX_CONCURRENT_JOBS=5
FIRECRAWL_REQUEST_TIMEOUT=30000

# Blocked domains (comma-separated, optional)
FIRECRAWL_BLOCKED_DOMAINS=facebook.com,instagram.com,twitter.com,reddit.com

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_HOST=firecrawl-redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=  # Leave empty if no auth

# ============================================
# MONITORING & LOGGING
# ============================================
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=30d
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin  # CHANGE THIS!

# ============================================
# BACKUP & MAINTENANCE
# ============================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/backups

# ============================================
# EMAIL NOTIFICATIONS (Optional)
# ============================================
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@optima.local
SMTP_TO_EMAIL=admin@optima.local

# ============================================
# API RATE LIMITING
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW=3600  # 1 hour
RATE_LIMIT_MAX_REQUESTS=100  # per window

# ============================================
# FEATURE FLAGS
# ============================================
FEATURE_PRICE_MONITORING=true
FEATURE_LEAD_GENERATION=true
FEATURE_AUTO_REPORTING=true
FEATURE_DEDUPLICATION=true

# ============================================
# SECURITY
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-this
ENCRYPTION_KEY=your-encryption-key-change-this
CORS_ENABLED=false
CORS_ORIGINS=localhost:5678

# ============================================
# PERFORMANCE TUNING
# ============================================
NODE_ENV=production
NODE_OPTIONS=--max-old-space-size=2048
GENERIC_FUNCTION_TIMEOUT=600  # 10 minutes
EXECUTION_TIMEOUT=3600  # 1 hour
DB_POOL_SIZE=20
DB_STATEMENT_CACHE_SIZE=10

# ============================================
# MISCELLANEOUS
# ============================================
PROJECT_NAME=PT Optima Smartindo - Web Scraping System
PROJECT_VERSION=1.0.0
MAINTENANCE_MODE=false
DEBUG_MODE=false

# ============================================
# NOTES
# ============================================
# 1. NEVER commit this file with real credentials to Git
# 2. Use different passwords for production
# 3. Rotate API keys regularly
# 4. Store sensitive values in secure vault (e.g., Vault, LastPass, 1Password)
# 5. Restrict file permissions: chmod 600 .env
# 6. Use .env.example as template for documentation
