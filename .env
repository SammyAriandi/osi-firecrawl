# ============================================
# .env - Environment Configuration
# PT Optima Smartindo Industry
# ============================================
# Copy this file as ".env" in the same folder as docker-compose.yml
# Then edit the values below.
#
# IMPORTANT: Do NOT use special characters like !@# in passwords
# as they break Docker Compose variable substitution.
# ============================================

# ============================================
# SYSTEM
# ============================================
TZ=Asia/Jakarta

# ============================================
# POSTGRESQL DATABASE
# ============================================
POSTGRES_USER=optima_user
POSTGRES_PASSWORD=OptimaSmartin123
POSTGRES_DB=optima_erp

# ============================================
# PGADMIN
# ============================================
PGADMIN_EMAIL=admin@optima.local
PGADMIN_PASSWORD=AdminOptima123

# ============================================
# N8N
# ============================================
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=Optima2024

# ============================================
# LLM PROVIDER (for Firecrawl AI extraction)
# ============================================
# Choose ONE option and fill in your API key.
# Firecrawl will be added as a separate step.

# Option 1: OpenAI (recommended for production)
LLM_PROVIDER=openai
LLM_API_KEY=sk-proj-YOUR_OPENAI_API_KEY_HERE
LLM_MODEL_NAME=gpt-4-turbo

# Option 2: Ollama (free, local) - uncomment below & comment Option 1
# LLM_PROVIDER=ollama
# LLM_API_KEY=dummy
# LLM_MODEL_NAME=mistral

# Option 3: Claude via OpenRouter - uncomment below & comment Option 1
# LLM_PROVIDER=openrouter
# LLM_API_KEY=sk-or-YOUR_OPENROUTER_KEY
# LLM_MODEL_NAME=anthropic/claude-3-sonnet
